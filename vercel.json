{
  "version": 2,
  "builds": [
    { "src": "server/src/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "server/src/index.js" },
    { "source": "/((?!api|.*\\.js|.*\\.css).*)", "destination": "/index.html" }
  ]
}